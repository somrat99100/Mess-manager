rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isMemberOf(messId) {
      return isSignedIn() && exists(/databases/$(database)/documents/messMembers/$(messId + '_' + request.auth.uid));
    }

    function myRoleIn(messId) {
      return get(/databases/$(database)/documents/messMembers/$(messId + '_' + request.auth.uid)).data.role;
    }

    function isManagerOf(messId) {
      return isSignedIn() && isMemberOf(messId) && myRoleIn(messId) == 'manager';
    }

    // Lunch/dinner cutoff times (HH:mm, evaluated in UTC — document this for non-UTC users) stored on the mess doc.
    // Firestore rules can't inspect which specific field inside a map write changed, so as a coarse
    // backstop we keep the member-write window open until BOTH cutoffs have passed; the client UI
    // is what actually enforces the exact per-meal-type cutoff (disabling the right toggle at the right time).
    function lunchDeadlineHour(messId) {
      return int(get(/databases/$(database)/documents/mess/$(messId)).data.lunchDeadline.split(':')[0]);
    }
    function dinnerDeadlineHour(messId) {
      return int(get(/databases/$(database)/documents/mess/$(messId)).data.dinnerDeadline.split(':')[0]);
    }
    // meals doc id is always "{messId}_{yyyy-mm-dd}" — messId itself never contains an
    // underscore (Firestore auto-ids don't use one), so splitting on '_' safely recovers both
    // pieces straight from the path. This lets us evaluate rules WITHOUT reading `resource.data`,
    // which is what's needed for reads/writes on dates that don't have a meals doc yet (e.g. a
    // future date nobody has touched) — `resource` is null there, and referencing `resource.data`
    // on a null resource is what previously caused "missing or insufficient permissions" errors.
    function mealMessId(mealId) {
      return mealId.split('_')[0];
    }
    function mealDateOf(mealId) {
      let parts = mealId.split('_')[1].split('-');
      return timestamp.date(int(parts[0]), int(parts[1]), int(parts[2]));
    }
    function todayDate() {
      return timestamp.date(request.time.year(), request.time.month(), request.time.day());
    }
    // Members can always write today-or-future dates before the relevant cutoff HOUR; the
    // date itself must not be in the past. Previously this only checked the current hour against
    // the cutoffs with no notion of date at all, so once today's cutoff hour had passed, members
    // (and the UI) were incorrectly locked out of editing FUTURE dates too.
    function beforeDeadline(messId, mealId) {
      return mealDateOf(mealId) > todayDate() ||
             (mealDateOf(mealId) == todayDate() &&
              (request.time.hours() < lunchDeadlineHour(messId) || request.time.hours() < dinnerDeadlineHour(messId)));
    }

    // ---------- users ----------
    // A user can only read/write their own profile document.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ---------- emailOtps ----------
    // Document id convention: {uid} — one active code per user. Generated, emailed (via
    // EmailJS), and checked entirely client-side, so only the user themself may ever
    // read or write their own code; nobody else can see or tamper with it.
    match /emailOtps/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---------- mess ----------
    match /mess/{messId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // creator immediately adds themself as manager in the same client flow
      allow update: if isManagerOf(messId);
      allow delete: if false;
    }

    // ---------- messMembers ----------
    // Document id convention: {messId}_{userId}
    match /messMembers/{docId} {
      allow read: if isSignedIn();

      // Creating a brand-new mess: the creator immediately adds themself as its manager.
      // Joining an existing mess now requires manager approval (see /joinRequests below), so a
      // self-service create is only allowed here for role == 'manager'. Adding an approved member
      // is instead done by the mess's current manager, on behalf of the approved user.
      allow create: if isSignedIn() && (
                      (request.resource.data.userId == request.auth.uid
                       && docId == request.resource.data.messId + '_' + request.auth.uid
                       && request.resource.data.role == 'manager') ||
                      (isManagerOf(request.resource.data.messId)
                       && docId == request.resource.data.messId + '_' + request.resource.data.userId)
                    );

      // Updates: a manager can update any member row in their mess (role, deposit, name).
      // A member may only update their own "name" field (kept in sync with their profile) — nothing else.
      allow update: if isSignedIn() && (
                      isManagerOf(resource.data.messId) ||
                      (request.auth.uid == resource.data.userId &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']))
                    );

      // A manager can remove any member. A member may also remove themself (leaving the mess
      // to join a different one) — used from the Profile tab's "Change mess" option.
      allow delete: if isSignedIn() && (
                      isManagerOf(resource.data.messId) ||
                      request.auth.uid == resource.data.userId
                    );
    }

    // ---------- meals ----------
    // Document id convention: {messId}_{yyyy-mm-dd}. Meal fields live in a `members` map keyed by userId.
    match /meals/{mealId} {
      // Derived from the doc path (mealId), not resource.data — so this also works for a date
      // that has no meals doc yet (resource is null), instead of erroring out as "permission denied".
      allow read: if isSignedIn() && isMemberOf(mealMessId(mealId));

      // Managers can write anything, anytime — any past, present, or future date.
      // Members can only write a merge that touches ONLY the `members` map (their own meal entry —
      // enforced together with the client, which only ever sends the caller's own uid key),
      // and only for today-or-future dates, before that mess's daily deadline hour on today.
      allow create, update: if isSignedIn() && (
        isManagerOf(request.resource.data.messId) ||
        (
          isMemberOf(request.resource.data.messId) &&
          beforeDeadline(request.resource.data.messId, mealId) &&
          request.resource.data.diff(resource == null ? {} : resource.data).affectedKeys()
            .hasOnly(['members', 'updatedAt', 'updatedBy', 'messId', 'date'])
        )
      );
      allow delete: if isManagerOf(resource.data.messId);
    }

    // ---------- mealOffRequests ----------
    // Created by a member after their deadline has passed, when they want a meal turned off.
    // Only the manager can approve/decline (which also writes the actual off-toggle into /meals);
    // the requesting member may cancel their own still-pending request.
    match /mealOffRequests/{reqId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);

      allow create: if isSignedIn()
                    && isMemberOf(request.resource.data.messId)
                    && request.resource.data.memberId == request.auth.uid
                    && request.resource.data.status == 'pending';

      allow update: if isSignedIn() && (
                      isManagerOf(resource.data.messId) ||
                      (request.auth.uid == resource.data.memberId &&
                       resource.data.status == 'pending' &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                       request.resource.data.status == 'cancelled')
                    );

      allow delete: if isManagerOf(resource.data.messId);
    }

    // ---------- guestRequests ----------
    // A member asks for N guest meals to be added on a date; only the manager can approve/decline
    // (approval also writes the +N into /meals). The requesting member may cancel their own pending one.
    match /guestRequests/{reqId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);

      allow create: if isSignedIn()
                    && isMemberOf(request.resource.data.messId)
                    && request.resource.data.memberId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.count is number
                    && request.resource.data.count > 0;

      allow update: if isSignedIn() && (
                      isManagerOf(resource.data.messId) ||
                      (request.auth.uid == resource.data.memberId &&
                       resource.data.status == 'pending' &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                       request.resource.data.status == 'cancelled')
                    );

      allow delete: if isManagerOf(resource.data.messId);
    }

    // ---------- managerRequests ----------
    // A member asks to become the mess's manager; only the current manager can approve/decline
    // (approval also runs the manager hand-off in the client). The requesting member may cancel
    // their own still-pending request.
    match /managerRequests/{reqId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);

      allow create: if isSignedIn()
                    && isMemberOf(request.resource.data.messId)
                    && request.resource.data.memberId == request.auth.uid
                    && request.resource.data.status == 'pending';

      allow update: if isSignedIn() && (
                      isManagerOf(resource.data.messId) ||
                      (request.auth.uid == resource.data.memberId &&
                       resource.data.status == 'pending' &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                       request.resource.data.status == 'cancelled')
                    );

      allow delete: if isManagerOf(resource.data.messId);
    }

    // ---------- joinRequests ----------
    // A signed-in user asks to join a mess using its invite code; only that mess's manager can
    // approve (which also creates the messMembers row in the client) or decline. Not yet a member
    // of the mess, so the requester is allowed to read/create/cancel their own request by uid alone.
    match /joinRequests/{reqId} {
      allow read: if isSignedIn() && (
                    request.auth.uid == resource.data.userId ||
                    isMemberOf(resource.data.messId)
                  );

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';

      allow update: if isSignedIn() && (
                      isManagerOf(resource.data.messId) ||
                      (request.auth.uid == resource.data.userId &&
                       resource.data.status == 'pending' &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                       request.resource.data.status == 'cancelled')
                    );

      allow delete: if isManagerOf(resource.data.messId);
    }

    // ---------- managerHistory ----------
    // Append-only log of who has managed the mess and for how long. Only the manager who is
    // still current AT THE MOMENT the write is evaluated can write it — the client submits every
    // write for a hand-off (closing the outgoing record, opening the new one, demoting/promoting
    // messMembers) as a single atomic batch, so the outgoing manager's own role hasn't flipped
    // to 'member' yet when these rules are checked.
    match /managerHistory/{recordId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create: if isSignedIn() && isManagerOf(request.resource.data.messId);
      allow update: if isSignedIn() && isManagerOf(resource.data.messId);
      allow delete: if false;
    }

    // ---------- expenses ----------
    // Only managers can create, edit, or delete expenses. Any mess member can read them.
    match /expenses/{expenseId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create: if isManagerOf(request.resource.data.messId);
      allow update, delete: if isManagerOf(resource.data.messId);
    }

    // ---------- notices ----------
    // Any member of the mess can post a notice at any time. Only the manager or the
    // original author can edit/remove one.
    match /notices/{noticeId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create: if isSignedIn()
                    && isMemberOf(request.resource.data.messId)
                    && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
                    isManagerOf(resource.data.messId) ||
                    request.auth.uid == resource.data.authorId
                  );
    }
  }
}
